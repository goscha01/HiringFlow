// ============ EMAIL & AUTOMATIONS ============

model EmailTemplate {
  id          String           @id @default(uuid())
  workspaceId String           @map("workspace_id")
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  createdById String           @map("created_by_id")
  name        String
  subject     String
  bodyHtml    String           @map("body_html")
  bodyText    String?          @map("body_text")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  automations AutomationRule[]
  steps       AutomationStep[]

  @@map("email_templates")
}

model AutomationRule {
  id                      String                @id @default(uuid())
  workspaceId             String                @map("workspace_id")
  workspace               Workspace             @relation(fields: [workspaceId], references: [id])
  createdById             String                @map("created_by_id")
  name                    String
  triggerType             String                @map("trigger_type")
  // Explicit funnel-stage assignment for the journey UI. The runtime engine
  // still dispatches by triggerType — stageId is just metadata that says
  // "this rule belongs to stage X in the applicant journey", overriding the
  // implicit triggerType→StageTrigger mapping. Nullable for back-compat:
  // older rules fall back to the implicit mapping. Stages live in JSON on
  // Workspace.settings, so this is intentionally a plain string (no FK).
  stageId                 String?               @map("stage_id")
  flowId                  String?               @map("flow_id")
  flow                    Flow?                 @relation(fields: [flowId], references: [id])
  triggerAutomationId     String?               @map("trigger_automation_id")
  triggerAutomation       AutomationRule?       @relation("AutomationChain", fields: [triggerAutomationId], references: [id])
  chainedBy               AutomationRule[]      @relation("AutomationChain")
  actionType              String                @default("send_email") @map("action_type")
  // 'email' (default) | 'sms'. Determines which send pipeline runs. Email
  // rules use emailTemplateId; SMS rules use smsBody (per-rule, no template
  // indirection in v1). Future channels: 'whatsapp'.
  channel                 String                @default("email")
  // Nullable for SMS rules. Required when channel='email' (validated at
  // API layer; the FK stays nullable for back-compat with future channels
  // that don't use email templates).
  emailTemplateId         String?               @map("email_template_id")
  emailTemplate           EmailTemplate?        @relation(fields: [emailTemplateId], references: [id])
  // Plaintext SMS body with merge tokens like {{candidate_name}}. Only used
  // when channel='sms'. Kept on the rule for v1 — no separate SmsTemplate
  // model yet.
  smsBody                 String?               @map("sms_body")
  emailDestination        String                @default("applicant") @map("email_destination") // 'applicant' | 'company' | 'specific'
  emailDestinationAddress String?               @map("email_destination_address")
  nextStepType            String?               @map("next_step_type")
  nextStepUrl             String?               @map("next_step_url")
  trainingId              String?               @map("training_id")
  training                Training?             @relation(fields: [trainingId], references: [id])
  schedulingConfigId      String?               @map("scheduling_config_id")
  schedulingConfig        SchedulingConfig?     @relation(fields: [schedulingConfigId], references: [id])
  delayMinutes            Int                   @default(0) @map("delay_minutes") // 0 = immediate
  // For triggerType='before_meeting' rules: how many minutes before
  // InterviewMeeting.scheduledStart to fire. e.g. 60 = "1 hour before".
  // Ignored for all other trigger types.
  minutesBefore           Int?                  @map("minutes_before")
  // When a meeting_ended rule has this set, execution is deferred until a
  // recording_ready event fires for the same session (or a 4h hard cutoff).
  waitForRecording        Boolean               @default(false) @map("wait_for_recording")
  isActive                Boolean               @default(true) @map("is_active")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  executions              AutomationExecution[]
  steps                   AutomationStep[]

  @@map("automation_rules")
}

// One send within an AutomationRule. A rule is now a *sequence* of steps
// instead of a single send: the trigger fires the rule, then each step is
// queued at its own delayMinutes (relative to the trigger event). channel
// can be 'email', 'sms', or 'both' — 'both' produces one AutomationExecution
// row per channel at run time.
//
// Existing rules are backfilled to a single step at order=0 carrying the
// rule's prior channel/body/template/destination/nextStep* fields. The
// legacy per-rule fields (channel, smsBody, emailTemplateId, etc.) remain on
// AutomationRule for back-compat with read paths during rollout but are no
// longer the source of truth — the executor reads from steps.
model AutomationStep {
  id                      String                @id @default(uuid())
  ruleId                  String                @map("rule_id")
  rule                    AutomationRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  order                   Int
  // How `delayMinutes` is interpreted:
  //  - 'trigger'        → minutes after the trigger event fired (default).
  //  - 'before_meeting' → minutes BEFORE InterviewMeeting.scheduledStart.
  //  - 'after_meeting'  → minutes AFTER InterviewMeeting.scheduledStart.
  // Only meaningful for triggers tied to a meeting (meeting_scheduled,
  // before_meeting, meeting_started, meeting_ended). Other triggers ignore
  // any non-'trigger' value and behave as 'trigger'.
  timingMode              String                @default("trigger") @map("timing_mode")
  delayMinutes            Int                   @default(0) @map("delay_minutes")
  // 'email' | 'sms' | 'both'. 'both' fans out into two executions at run time.
  channel                 String                @default("email")
  emailTemplateId         String?               @map("email_template_id")
  emailTemplate           EmailTemplate?        @relation(fields: [emailTemplateId], references: [id])
  smsBody                 String?               @map("sms_body")
  emailDestination        String                @default("applicant") @map("email_destination")
  emailDestinationAddress String?               @map("email_destination_address")
  // Per-step next-step config (for steps that include a scheduling/training
  // CTA in the body — e.g. the post-training scheduling-invite step).
  nextStepType            String?               @map("next_step_type")
  nextStepUrl             String?               @map("next_step_url")
  trainingId              String?               @map("training_id")
  training                Training?             @relation("StepTraining", fields: [trainingId], references: [id])
  schedulingConfigId      String?               @map("scheduling_config_id")
  schedulingConfig        SchedulingConfig?     @relation("StepSchedulingConfig", fields: [schedulingConfigId], references: [id])
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  executions              AutomationExecution[]

  @@unique([ruleId, order])
  @@map("automation_steps")
}

model AutomationExecution {
  id                String          @id @default(uuid())
  automationRuleId  String          @map("automation_rule_id")
  automationRule    AutomationRule  @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  // Nullable for back-compat with pre-migration executions that predate the
  // step model. New rows MUST set stepId — backfilled for legacy rows.
  stepId            String?         @map("step_id")
  // SetNull (not Cascade) so editing a rule and replacing its steps doesn't
  // wipe the execution history. Orphan rows keep their ruleId, sessionId,
  // status, providerMessageId, sentAt — stepId becomes null, which is fine
  // since the unique constraint allows nulls.
  step              AutomationStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  sessionId         String?         @map("session_id")
  status            String          @default("pending")
  errorMessage      String?         @map("error_message")
  // 'sendgrid' for email, 'sigcore' for SMS via the Sigcore platform API.
  provider          String          @default("sendgrid")
  providerMessageId String?         @map("provider_message_id")
  // Mirror of the step's channel at execution time. Lets the timeline UI
  // show which channel actually ran without joining to the step (its channel
  // could change after execution). For step.channel='both', each channel
  // gets its own execution row with channel='email' or 'sms'.
  channel           String          @default("email")
  // QStash messageId — captured when a delayed rule is queued so we can
  // cancel/delete the scheduled job (e.g. when a meeting is cancelled or
  // rescheduled and pending reminders need to be voided).
  qstashMessageId   String?         @map("qstash_message_id")
  sentAt            DateTime?       @map("sent_at")
  scheduledFor      DateTime?       @map("scheduled_for")
  createdAt         DateTime        @default(now()) @map("created_at")

  // One execution per (step, session, channel). channel is in the key so
  // step.channel='both' can produce one email and one sms execution for the
  // same session without colliding.
  @@unique([stepId, sessionId, channel])
  @@map("automation_executions")
}

// ============ SCHEDULING ============

model SchedulingConfig {
  id              String            @id @default(uuid())
  workspaceId     String            @map("workspace_id")
  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  createdById     String            @map("created_by_id")
  name            String
  provider        String            @default("calendly")
  schedulingUrl   String            @map("scheduling_url")
  isDefault       Boolean           @default(false) @map("is_default")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  automationRules AutomationRule[]
  automationSteps AutomationStep[]  @relation("StepSchedulingConfig")
  events          SchedulingEvent[]

  @@map("scheduling_configs")
}

model SchedulingEvent {
  id                 String            @id @default(uuid())
  sessionId          String            @map("session_id")
  session            Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  schedulingConfigId String?           @map("scheduling_config_id")
  schedulingConfig   SchedulingConfig? @relation(fields: [schedulingConfigId], references: [id])
  eventType          String            @map("event_type")
  eventAt            DateTime          @default(now()) @map("event_at")
  metadata           Json?
  createdAt          DateTime          @default(now()) @map("created_at")

  @@map("scheduling_events")
}
