generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  videos       Video[]
  flows        Flow[]
  trainings    Training[]

  @@map("users")
}

model Video {
  id              String     @id @default(uuid())
  ownerUserId     String     @map("owner_user_id")
  owner           User       @relation(fields: [ownerUserId], references: [id])
  filename        String
  storageKey      String     @map("storage_key")
  mimeType        String     @map("mime_type")
  sizeBytes       Int        @map("size_bytes")
  durationSeconds Float?     @map("duration_seconds")
  transcript      String?
  segments        Json?
  summary         String?
  bulletPoints    String[]   @default([]) @map("bullet_points")
  displayName     String?    @map("display_name")
  createdAt       DateTime          @default(now()) @map("created_at")
  steps           FlowStep[]
  trainingContents TrainingContent[]

  @@map("videos")
}

model Flow {
  id           String     @id @default(uuid())
  ownerUserId  String     @map("owner_user_id")
  owner        User       @relation(fields: [ownerUserId], references: [id])
  name         String
  slug         String     @unique
  isPublished  Boolean    @default(false) @map("is_published")
  startMessage String     @default("Welcome! Please complete the following steps.") @map("start_message")
  endMessage   String     @default("Thank you for your participation!") @map("end_message")
  branding     Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  steps        FlowStep[]
  sessions     Session[]

  @@map("flows")
}

model FlowStep {
  id              String                @id @default(uuid())
  flowId          String                @map("flow_id")
  flow            Flow                  @relation(fields: [flowId], references: [id], onDelete: Cascade)
  title           String
  videoId         String?               @map("video_id")
  video           Video?                @relation(fields: [videoId], references: [id])
  questionText    String?               @map("question_text")
  stepOrder       Int                   @default(0) @map("step_order")
  stepType        String                @default("question") @map("step_type") // 'question' | 'submission' | 'form' | 'info'
  questionType    String                @default("single") @map("question_type") // 'single' | 'multiselect' | 'button' | 'yesno' | 'text'
  formEnabled     Boolean               @default(false) @map("form_enabled")
  formConfig      Json?                 @map("form_config")
  infoContent     String?               @map("info_content") // Rich text for info steps
  captionsEnabled Boolean               @default(false) @map("captions_enabled")
  captionStyle    Json?                 @map("caption_style")
  createdAt       DateTime              @default(now()) @map("created_at")
  options         StepOption[]          @relation("StepOptions")
  incomingOptions StepOption[]          @relation("NextStep")
  answers         SessionAnswer[]
  submissions     CandidateSubmission[]
  sessions        Session[]             @relation("LastStep")

  @@map("flow_steps")
}

model StepOption {
  id         String          @id @default(uuid())
  stepId     String          @map("step_id")
  step       FlowStep        @relation("StepOptions", fields: [stepId], references: [id], onDelete: Cascade)
  optionText String          @map("option_text")
  nextStepId String?         @map("next_step_id")
  nextStep   FlowStep?       @relation("NextStep", fields: [nextStepId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now()) @map("created_at")
  answers    SessionAnswer[]

  @@map("step_options")
}

model Session {
  id             String                @id @default(uuid())
  flowId         String                @map("flow_id")
  flow           Flow                  @relation(fields: [flowId], references: [id], onDelete: Cascade)
  candidateName  String?               @map("candidate_name")
  candidateEmail String?               @map("candidate_email")
  candidatePhone String?               @map("candidate_phone")
  formData       Json?                 @map("form_data")
  startedAt      DateTime              @default(now()) @map("started_at")
  finishedAt     DateTime?             @map("finished_at")
  outcome        String?               // 'completed' | 'passed' | 'failed' | 'abandoned'
  lastStepId     String?               @map("last_step_id")
  lastStep       FlowStep?             @relation("LastStep", fields: [lastStepId], references: [id])
  // Source attribution (for future ad/campaign tracking)
  adId           String?               @map("ad_id")
  campaignId     String?               @map("campaign_id")
  source         String?
  answers        SessionAnswer[]
  submissions    CandidateSubmission[]

  @@map("sessions")
}

model SessionAnswer {
  id         String      @id @default(uuid())
  sessionId  String      @map("session_id")
  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId     String      @map("step_id")
  step       FlowStep    @relation(fields: [stepId], references: [id])
  optionId   String?     @map("option_id")
  option     StepOption? @relation(fields: [optionId], references: [id])
  answeredAt DateTime    @default(now()) @map("answered_at")

  @@index([sessionId, stepId])
  @@map("session_answers")
}

model CandidateSubmission {
  id              String   @id @default(uuid())
  sessionId       String   @map("session_id")
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId          String   @map("step_id")
  step            FlowStep @relation(fields: [stepId], references: [id])
  videoStorageKey String?  @map("video_storage_key")
  videoFilename   String?  @map("video_filename")
  videoMimeType   String?  @map("video_mime_type")
  videoSizeBytes  Int?     @map("video_size_bytes")
  textMessage     String?  @map("text_message")
  submittedAt     DateTime @default(now()) @map("submitted_at")

  @@unique([sessionId, stepId])
  @@map("candidate_submissions")
}

// ============ TRAININGS ============

model Training {
  id            String            @id @default(uuid())
  ownerUserId   String            @map("owner_user_id")
  owner         User              @relation(fields: [ownerUserId], references: [id])
  title         String
  slug          String            @unique
  description   String?
  coverImage    String?           @map("cover_image")
  timeLimit     Json?             @map("time_limit") // { type: 'unlimited' | 'days' | 'calendar', value?: number, date?: string }
  pricing       Json?             // { type: 'free' | 'paid', price?: number, currency?: string }
  passingGrade  Int               @default(80) @map("passing_grade")
  isPublished   Boolean           @default(false) @map("is_published")
  branding      Json?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  sections      TrainingSection[]
  enrollments   TrainingEnrollment[]

  @@map("trainings")
}

model TrainingSection {
  id          String             @id @default(uuid())
  trainingId  String             @map("training_id")
  training    Training           @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  title       String
  sortOrder   Int                @default(0) @map("sort_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  contents    TrainingContent[]
  quiz        TrainingQuiz?

  @@map("training_sections")
}

model TrainingContent {
  id          String          @id @default(uuid())
  sectionId   String          @map("section_id")
  section     TrainingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type        String          // 'video' | 'text'
  sortOrder   Int             @default(0) @map("sort_order")
  // Video fields
  videoId     String?         @map("video_id")
  video       Video?          @relation(fields: [videoId], references: [id])
  requiredWatch Boolean       @default(true) @map("required_watch")
  autoplayNext  Boolean       @default(true) @map("autoplay_next")
  // Text fields
  textContent String?         @map("text_content")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("training_contents")
}

model TrainingQuiz {
  id              String             @id @default(uuid())
  sectionId       String             @unique @map("section_id")
  section         TrainingSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title           String
  requiredPassing Boolean            @default(true) @map("required_passing")
  passingGrade    Int                @default(80) @map("passing_grade")
  createdAt       DateTime           @default(now()) @map("created_at")
  questions       TrainingQuestion[]

  @@map("training_quizzes")
}

model TrainingQuestion {
  id           String       @id @default(uuid())
  quizId       String       @map("quiz_id")
  quiz         TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText String       @map("question_text")
  questionType String       @default("single") @map("question_type") // 'single' | 'multiselect'
  sortOrder    Int          @default(0) @map("sort_order")
  options      Json         // [{ text: string, isCorrect: boolean }]
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("training_questions")
}

model TrainingEnrollment {
  id          String    @id @default(uuid())
  trainingId  String    @map("training_id")
  training    Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  userName    String?   @map("user_name")
  userEmail   String?   @map("user_email")
  progress    Json?     // { completedSections: string[], quizScores: { sectionId: score }[] }
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@map("training_enrollments")
}
