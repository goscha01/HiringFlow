generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ IDENTITY & WORKSPACE ============

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  isSuperAdmin Boolean  @default(false) @map("is_super_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  memberships  WorkspaceMember[]

  @@map("users")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        String   @default("free") // 'free' | 'starter' | 'pro' | 'enterprise'
  isActive    Boolean  @default(true) @map("is_active")
  website     String?
  phone       String?
  timezone    String   @default("America/New_York")
  logoUrl     String?  @map("logo_url")
  senderName  String?  @map("sender_name")  // from name for emails
  senderEmail String?  @map("sender_email") // reply-to for emails
  settings    Json?    // extensible provider config: { indeed: {...}, calendly: {...} }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members           WorkspaceMember[]
  videos            Video[]
  flows             Flow[]
  ads               Ad[]
  sessions          Session[]
  trainings         Training[]
  emailTemplates    EmailTemplate[]
  automationRules   AutomationRule[]
  schedulingConfigs SchedulingConfig[]
  adTemplates       AdTemplate[]
  aiCallConfigs     AICallConfig[]
  aiCallCandidates  AICallCandidate[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String   @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        String   @default("owner") // 'owner' | 'admin' | 'member'
  joinedAt    DateTime @default(now()) @map("joined_at")

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general") // 'general' | 'providers' | 'email' | 'integrations'
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ============ VIDEOS ============

model Video {
  id              String     @id @default(uuid())
  workspaceId     String     @map("workspace_id")
  workspace       Workspace  @relation(fields: [workspaceId], references: [id])
  createdById     String     @map("created_by_id")
  filename        String
  storageKey      String     @map("storage_key")
  mimeType        String     @map("mime_type")
  sizeBytes       Int        @map("size_bytes")
  durationSeconds Float?     @map("duration_seconds")
  transcript      String?
  segments        Json?
  summary         String?
  bulletPoints    String[]   @default([]) @map("bullet_points")
  displayName     String?    @map("display_name")
  createdAt       DateTime   @default(now()) @map("created_at")
  steps           FlowStep[]
  trainingContents TrainingContent[]

  @@map("videos")
}

// ============ FLOWS ============

model Flow {
  id           String     @id @default(uuid())
  workspaceId  String     @map("workspace_id")
  workspace    Workspace  @relation(fields: [workspaceId], references: [id])
  createdById  String     @map("created_by_id")
  name         String
  slug         String     @unique
  isPublished  Boolean    @default(false) @map("is_published")
  startMessage String     @default("Welcome! Please complete the following steps.") @map("start_message")
  endMessage   String     @default("Thank you for your participation!") @map("end_message")
  branding     Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  steps           FlowStep[]
  sessions        Session[]
  ads             Ad[]
  automationRules AutomationRule[]

  @@map("flows")
}

model Ad {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdById String    @map("created_by_id")
  name        String
  source      String    // 'indeed' | 'facebook' | 'craigslist' | 'google' | 'linkedin' | 'other'
  campaign    String?
  flowId      String    @map("flow_id")
  flow        Flow      @relation(fields: [flowId], references: [id])
  slug        String    @unique
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  sessions    Session[]

  @@map("ads")
}

model FlowStep {
  id              String                @id @default(uuid())
  flowId          String                @map("flow_id")
  flow            Flow                  @relation(fields: [flowId], references: [id], onDelete: Cascade)
  title           String
  videoId         String?               @map("video_id")
  video           Video?                @relation(fields: [videoId], references: [id])
  questionText    String?               @map("question_text")
  stepOrder       Int                   @default(0) @map("step_order")
  stepType        String                @default("question") @map("step_type")
  questionType    String                @default("single") @map("question_type")
  formEnabled     Boolean               @default(false) @map("form_enabled")
  formConfig      Json?                 @map("form_config")
  infoContent     String?               @map("info_content")
  buttonConfig    Json?                 @map("button_config")
  combinedWithId  String?               @map("combined_with_id")
  captionsEnabled Boolean               @default(false) @map("captions_enabled")
  captionStyle    Json?                 @map("caption_style")
  createdAt       DateTime              @default(now()) @map("created_at")
  options         StepOption[]          @relation("StepOptions")
  incomingOptions StepOption[]          @relation("NextStep")
  answers         SessionAnswer[]
  submissions     CandidateSubmission[]
  sessions        Session[]             @relation("LastStep")

  @@map("flow_steps")
}

model StepOption {
  id         String          @id @default(uuid())
  stepId     String          @map("step_id")
  step       FlowStep        @relation("StepOptions", fields: [stepId], references: [id], onDelete: Cascade)
  optionText String          @map("option_text")
  nextStepId String?         @map("next_step_id")
  nextStep   FlowStep?       @relation("NextStep", fields: [nextStepId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now()) @map("created_at")
  answers    SessionAnswer[]

  @@map("step_options")
}

// ============ SESSIONS / CANDIDATES ============

model Session {
  id             String                @id @default(uuid())
  workspaceId    String                @map("workspace_id")
  workspace      Workspace             @relation(fields: [workspaceId], references: [id])
  flowId         String                @map("flow_id")
  flow           Flow                  @relation(fields: [flowId], references: [id], onDelete: Cascade)
  candidateName  String?               @map("candidate_name")
  candidateEmail String?               @map("candidate_email")
  candidatePhone String?               @map("candidate_phone")
  formData       Json?                 @map("form_data")
  startedAt      DateTime              @default(now()) @map("started_at")
  finishedAt     DateTime?             @map("finished_at")
  outcome        String?               // 'completed' | 'passed' | 'failed' | 'abandoned'
  pipelineStatus String?               @map("pipeline_status")
  lastStepId     String?               @map("last_step_id")
  lastStep       FlowStep?             @relation("LastStep", fields: [lastStepId], references: [id])
  adId           String?               @map("ad_id")
  ad             Ad?                   @relation(fields: [adId], references: [id])
  campaign       String?
  source         String?
  answers        SessionAnswer[]
  submissions    CandidateSubmission[]
  trainingEnrollments TrainingEnrollment[]
  trainingAccessTokens TrainingAccessToken[] @relation("AccessTokenSession")
  schedulingEvents    SchedulingEvent[]
  aiCalls             AICall[]

  @@map("sessions")
}

model SessionAnswer {
  id         String      @id @default(uuid())
  sessionId  String      @map("session_id")
  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId     String      @map("step_id")
  step       FlowStep    @relation(fields: [stepId], references: [id])
  optionId   String?     @map("option_id")
  option     StepOption? @relation(fields: [optionId], references: [id])
  answeredAt DateTime    @default(now()) @map("answered_at")

  @@index([sessionId, stepId])
  @@map("session_answers")
}

model CandidateSubmission {
  id              String   @id @default(uuid())
  sessionId       String   @map("session_id")
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId          String   @map("step_id")
  step            FlowStep @relation(fields: [stepId], references: [id])
  videoStorageKey String?  @map("video_storage_key")
  videoFilename   String?  @map("video_filename")
  videoMimeType   String?  @map("video_mime_type")
  videoSizeBytes  Int?     @map("video_size_bytes")
  textMessage     String?  @map("text_message")
  submittedAt     DateTime @default(now()) @map("submitted_at")

  @@unique([sessionId, stepId])
  @@map("candidate_submissions")
}

// ============ TRAININGS ============

model Training {
  id            String            @id @default(uuid())
  workspaceId   String            @map("workspace_id")
  workspace     Workspace         @relation(fields: [workspaceId], references: [id])
  createdById   String            @map("created_by_id")
  title         String
  slug          String            @unique
  description   String?
  coverImage    String?           @map("cover_image")
  timeLimit     Json?             @map("time_limit")
  pricing       Json?
  passingGrade  Int               @default(80) @map("passing_grade")
  isPublished   Boolean           @default(false) @map("is_published")
  accessMode    String            @default("public") @map("access_mode")
  branding      Json?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  sections      TrainingSection[]
  enrollments   TrainingEnrollment[]
  accessTokens  TrainingAccessToken[]
  automationRules AutomationRule[]

  @@map("trainings")
}

model TrainingSection {
  id          String             @id @default(uuid())
  trainingId  String             @map("training_id")
  training    Training           @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  title       String
  sortOrder   Int                @default(0) @map("sort_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  contents    TrainingContent[]
  quiz        TrainingQuiz?

  @@map("training_sections")
}

model TrainingContent {
  id          String          @id @default(uuid())
  sectionId   String          @map("section_id")
  section     TrainingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type        String
  sortOrder   Int             @default(0) @map("sort_order")
  videoId     String?         @map("video_id")
  video       Video?          @relation(fields: [videoId], references: [id])
  requiredWatch Boolean       @default(true) @map("required_watch")
  autoplayNext  Boolean       @default(true) @map("autoplay_next")
  textContent String?         @map("text_content")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("training_contents")
}

model TrainingQuiz {
  id              String             @id @default(uuid())
  sectionId       String             @unique @map("section_id")
  section         TrainingSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title           String
  requiredPassing Boolean            @default(true) @map("required_passing")
  passingGrade    Int                @default(80) @map("passing_grade")
  createdAt       DateTime           @default(now()) @map("created_at")
  questions       TrainingQuestion[]

  @@map("training_quizzes")
}

model TrainingQuestion {
  id           String       @id @default(uuid())
  quizId       String       @map("quiz_id")
  quiz         TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText String       @map("question_text")
  questionType String       @default("single") @map("question_type")
  sortOrder    Int          @default(0) @map("sort_order")
  options      Json
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("training_questions")
}

model TrainingEnrollment {
  id            String    @id @default(uuid())
  trainingId    String    @map("training_id")
  training      Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  userName      String?   @map("user_name")
  userEmail     String?   @map("user_email")
  sessionId     String?   @map("session_id")
  session       Session?  @relation(fields: [sessionId], references: [id])
  accessTokenId String?   @map("access_token_id")
  accessToken   TrainingAccessToken? @relation(fields: [accessTokenId], references: [id])
  status        String    @default("not_started")
  progress      Json?
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")

  @@unique([trainingId, accessTokenId])
  @@map("training_enrollments")
}

model TrainingAccessToken {
  id            String    @id @default(uuid())
  token         String    @unique
  candidateId   String?   @map("candidate_id")
  candidate     Session?  @relation("AccessTokenSession", fields: [candidateId], references: [id])
  trainingId    String    @map("training_id")
  training      Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  sourceType    String    @default("automation") @map("source_type")
  sourceRefId   String?   @map("source_ref_id")
  status        String    @default("active")
  expiresAt     DateTime? @map("expires_at")
  usedAt        DateTime? @map("used_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  enrollments   TrainingEnrollment[]

  @@map("training_access_tokens")
}

// ============ AI CALLS ============

model AICallConfig {
  id             String   @id @default(uuid())
  workspaceId    String   @map("workspace_id")
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  createdById    String   @map("created_by_id")
  name           String
  slug           String   @unique
  agentId        String   @map("agent_id") // ElevenLabs agent ID
  requiredCalls  Int      @default(1) @map("required_calls")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  calls          AICall[]

  @@map("ai_call_configs")
}

model AICall {
  id           String   @id @default(uuid())
  configId     String   @map("config_id")
  config       AICallConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  sessionId    String?  @map("session_id")
  session      Session? @relation(fields: [sessionId], references: [id])
  candidateName  String? @map("candidate_name")
  candidateEmail String? @map("candidate_email")
  callNumber   Int      @default(1) @map("call_number")
  status       String   @default("pending") // 'pending' | 'in_progress' | 'completed' | 'failed'
  durationSecs Int?     @map("duration_secs")
  transcript   Json?
  evaluation   Json?    // AI evaluation results
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_calls")
}

model AICallCandidate {
  id               String   @id @default(uuid())
  workspaceId      String   @map("workspace_id")
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  name             String
  agentId          String   @map("agent_id")
  conversationIds  String[] @default([]) @map("conversation_ids") // ElevenLabs conversation IDs
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("ai_call_candidates")
}

// ============ AD TEMPLATES ============

model AdTemplate {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdById String    @map("created_by_id")
  name        String
  source      String    // 'indeed' | 'facebook' | 'craigslist' | 'google' | 'linkedin' | 'other' | 'general'
  headline    String
  bodyText    String    @map("body_text")
  requirements String?
  benefits    String?
  callToAction String?  @map("call_to_action")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("ad_templates")
}

// ============ EMAIL & AUTOMATIONS ============

model EmailTemplate {
  id          String              @id @default(uuid())
  workspaceId String              @map("workspace_id")
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  createdById String              @map("created_by_id")
  name        String
  subject     String
  bodyHtml    String              @map("body_html")
  bodyText    String?             @map("body_text")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  automations AutomationRule[]

  @@map("email_templates")
}

model AutomationRule {
  id              String              @id @default(uuid())
  workspaceId     String              @map("workspace_id")
  workspace       Workspace           @relation(fields: [workspaceId], references: [id])
  createdById     String              @map("created_by_id")
  name            String
  triggerType     String              @map("trigger_type")
  flowId          String?             @map("flow_id")
  flow            Flow?               @relation(fields: [flowId], references: [id])
  actionType      String              @default("send_email") @map("action_type")
  emailTemplateId String              @map("email_template_id")
  emailTemplate   EmailTemplate       @relation(fields: [emailTemplateId], references: [id])
  nextStepType    String?             @map("next_step_type")
  nextStepUrl     String?             @map("next_step_url")
  trainingId      String?             @map("training_id")
  training        Training?           @relation(fields: [trainingId], references: [id])
  schedulingConfigId String?          @map("scheduling_config_id")
  schedulingConfig   SchedulingConfig? @relation(fields: [schedulingConfigId], references: [id])
  delayMinutes    Int                 @default(0) @map("delay_minutes") // 0 = immediate
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  executions      AutomationExecution[]

  @@map("automation_rules")
}

model AutomationExecution {
  id                String          @id @default(uuid())
  automationRuleId  String          @map("automation_rule_id")
  automationRule    AutomationRule  @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  sessionId         String?         @map("session_id")
  status            String          @default("pending")
  errorMessage      String?         @map("error_message")
  provider          String          @default("sendgrid")
  providerMessageId String?         @map("provider_message_id")
  sentAt            DateTime?       @map("sent_at")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@unique([automationRuleId, sessionId])
  @@map("automation_executions")
}

// ============ SCHEDULING ============

model SchedulingConfig {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  createdById   String    @map("created_by_id")
  name          String
  provider      String    @default("calendly")
  schedulingUrl String    @map("scheduling_url")
  isDefault     Boolean   @default(false) @map("is_default")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  automationRules AutomationRule[]
  events        SchedulingEvent[]

  @@map("scheduling_configs")
}

model SchedulingEvent {
  id                 String           @id @default(uuid())
  sessionId          String           @map("session_id")
  session            Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  schedulingConfigId String?          @map("scheduling_config_id")
  schedulingConfig   SchedulingConfig? @relation(fields: [schedulingConfigId], references: [id])
  eventType          String           @map("event_type")
  eventAt            DateTime         @default(now()) @map("event_at")
  metadata           Json?
  createdAt          DateTime         @default(now()) @map("created_at")

  @@map("scheduling_events")
}
